name: deploy
on:
  push:
    branches:
      - main  
permissions:
  contents: write  # 
jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: 3.x
      - run: pip install mkdocs-material
      - run: pip install mkdocs-static-i18n  # 你的双语插件
      - run: mkdocs gh-deploy --force
